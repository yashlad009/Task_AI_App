{
  "expo": {
    "name": "Task Tracker",
    "slug": "tasktracker-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yashlad.tasktracker"
    },
    "android": {
      "package": "com.yashlad.tasktracker",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F1A"
      }
    },
    "plugins": [
      "expo-router",
      "expo-notifications"
    ],
    "scheme": "tasktracker",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f3d2a0bb-82a5-4192-ac66-20b76092195c"
      }
    },
    "owner": "yashlad009"
  }
}
